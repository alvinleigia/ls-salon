# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# Auth
AUTH_SECRET="replace-with-a-long-random-secret"

# Tenant routing
APP_ROOT_DOMAIN="localhost"
PLATFORM_ADMIN_TENANT_SLUG="platform"
PLATFORM_ADMIN_TENANT_NAME="Platform Tenant"
PLATFORM_ADMIN_EMAIL="admin@example.com"
PLATFORM_ADMIN_PASSWORD="replace-with-a-secure-password"
NEXT_PUBLIC_PLATFORM_ADMIN_TENANT_SLUG="platform"

# Optional email delivery
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="smtp-user"
# SMTP_PASS="smtp-password"
# MAIL_FROM="LS Salon <noreply@example.com>"

# Optional Vercel custom-domain automation
# Create a Vercel access token, then add these same values in Vercel Project Settings > Environment Variables.
# Locally, copy this file to .env.local and uncomment/fill these values to test custom-domain provisioning.
# VERCEL_API_TOKEN="vercel-token-with-project-domain-access"
# VERCEL_PROJECT_ID="prj_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# VERCEL_PROJECT_NAME="ls-salon"
# VERCEL_TEAM_ID="team_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Optional app integrations
# INVOICE_FONT_PATH="/absolute/path/to/font.ttf"
# INVOICE_HEADER_LINES="Line one|Line two"
# NEXT_PUBLIC_SYNCFUSION_LICENSE_KEY="syncfusion-license-key"
