// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  STAFF
  CUSTOMER
}

enum Gender {
  MALE
  FEMALE
  NON_BINARY
  OTHER
  PREFER_NOT_TO_SAY
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  INVITED
  ARCHIVED
}

enum ServiceCategoryStatus {
  ACTIVE
  INACTIVE
}

enum ServiceStatus {
  ACTIVE
  INACTIVE
}

enum ServiceType {
  STANDARD
  PACKAGE
}

enum StaffDocumentType {
  ADDRESS
  ID
  OTHER
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum AppSettingPeriodType {
  WORK
  BREAK
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  phone         String?
  passwordHash  String?
  role          Role      @default(CUSTOMER)
  dateOfBirth   DateTime?
  gender        Gender?
  status        UserStatus @default(ACTIVE)
  lastLoginAt   DateTime?
  marketingOptIn Boolean   @default(false)
  addressLine1  String?
  addressLine2  String?
  city          String?
  state         String?
  postalCode    String?
  country       String?
  accounts      Account[]
  sessions      Session[]
  invitations   Invitation[] @relation("UserInvitations")
  passwordResetTokens PasswordResetToken[]
  eligibleServices StaffServiceEligibility[]
  staffProfile  StaffProfile?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ServiceCategory {
  id          String                 @id @default(cuid())
  name        String                 @unique
  description String?
  status      ServiceCategoryStatus  @default(ACTIVE)
  sortOrder   Int                    @default(0)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  services    Service[]

  @@index([status])
  @@index([sortOrder])
}

model Service {
  id              String        @id @default(cuid())
  name            String
  description     String?
  durationMinutes Int
  priceCents      Int
  status          ServiceStatus @default(ACTIVE)
  type            ServiceType   @default(STANDARD)
  categoryId      String
  category        ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  packageItems    ServicePackageItem[] @relation("PackageItems")
  includedIn      ServicePackageItem[] @relation("PackageItemService")
  eligibleStaff   StaffServiceEligibility[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status])
  @@index([categoryId])
  @@index([createdAt])
}

model ServicePackageItem {
  id             String   @id @default(cuid())
  packageId      String
  itemServiceId  String
  sortOrder      Int      @default(0)
  package        Service  @relation("PackageItems", fields: [packageId], references: [id], onDelete: Cascade)
  itemService    Service  @relation("PackageItemService", fields: [itemServiceId], references: [id], onDelete: Restrict)
  createdAt      DateTime @default(now())

  @@unique([packageId, itemServiceId])
  @@index([packageId])
  @@index([itemServiceId])
}

model AppSetting {
  id         String   @id @default("global")
  locale     String   @default("en-US")
  currency   String   @default("USD")
  timeZone   String   @default("America/New_York")
  dateFormat String   @default("MM/dd/yyyy")
  updatedAt  DateTime @updatedAt
  workingDays AppSettingDay[]
  overrides  AppSettingOverride[]
}

model AppSettingDay {
  id        String   @id @default(cuid())
  settingId String
  day       Weekday
  isOpen    Boolean  @default(true)
  setting   AppSetting @relation(fields: [settingId], references: [id], onDelete: Cascade)
  periods   AppSettingPeriod[]

  @@unique([settingId, day])
}

model AppSettingPeriod {
  id        String   @id @default(cuid())
  dayId     String
  kind      AppSettingPeriodType
  startTime String
  endTime   String
  sortOrder Int      @default(0)
  day       AppSettingDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@index([dayId])
}

model AppSettingOverride {
  id        String   @id @default(cuid())
  settingId String
  date      DateTime
  isOpen    Boolean  @default(true)
  setting   AppSetting @relation(fields: [settingId], references: [id], onDelete: Cascade)
  periods   AppSettingOverridePeriod[]

  @@unique([settingId, date])
  @@index([settingId])
  @@index([date])
}

model AppSettingOverridePeriod {
  id        String   @id @default(cuid())
  overrideId String
  kind      AppSettingPeriodType
  startTime String
  endTime   String
  sortOrder Int      @default(0)
  override  AppSettingOverride @relation(fields: [overrideId], references: [id], onDelete: Cascade)

  @@index([overrideId])
}

model StaffServiceEligibility {
  id        String   @id @default(cuid())
  userId    String
  serviceId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())

  @@unique([userId, serviceId])
  @@index([userId])
  @@index([serviceId])
}

model StaffProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  certifications     StaffCertification[]
  documents          StaffDocument[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model StaffCertification {
  id             String   @id @default(cuid())
  staffProfileId String
  title          String
  issuer         String?
  issuedAt       DateTime?
  expiresAt      DateTime?
  staffProfile   StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@index([staffProfileId])
}

model StaffDocument {
  id             String   @id @default(cuid())
  staffProfileId String
  type           StaffDocumentType
  number         String?
  imageUrl       String
  validFrom      DateTime?
  validTo        DateTime?
  staffProfile   StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@index([staffProfileId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Invitation {
  id          String      @id @default(cuid())
  email       String
  token       String      @unique
  role        Role        @default(CUSTOMER)
  expiresAt   DateTime
  acceptedAt DateTime?
  invitedById String?
  invitedBy   User?       @relation("UserInvitations", fields: [invitedById], references: [id], onDelete: SetNull)
  createdAt   DateTime    @default(now())

  @@index([email])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
