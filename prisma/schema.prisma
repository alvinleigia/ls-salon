// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  STAFF
  CUSTOMER
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum Gender {
  MALE
  FEMALE
  NON_BINARY
  OTHER
  PREFER_NOT_TO_SAY
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  INVITED
  ARCHIVED
}

enum ServiceCategoryStatus {
  ACTIVE
  INACTIVE
}

enum ServiceStatus {
  ACTIVE
  INACTIVE
}

enum ServiceType {
  STANDARD
  PACKAGE
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELED
  NO_SHOW
}

enum AppointmentOrderStatus {
  DRAFT
  CONFIRMED
  COMPLETED
  CANCELED
}

enum DiscountType {
  NONE
  PERCENT
  AMOUNT
}

enum CouponAppliesTo {
  ORDER
  SERVICE_LINES
  PRODUCT_LINES
}

enum CouponStackingMode {
  STACKABLE
  EXCLUSIVE
}

enum StaffDocumentType {
  ADDRESS
  ID
  OTHER
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum AppSettingPeriodType {
  WORK
  BREAK
}

enum CurrencySymbolPlacement {
  BEFORE
  AFTER
}

enum NumberFormatStyle {
  US_UK
  EUROPEAN
  ISO_DECIMAL_POINT
  ISO_DECIMAL_COMMA
  COMPACT_DECIMAL_POINT
  COMPACT_DECIMAL_COMMA
}

enum TimeFormat {
  H12
  H24
}

enum TaxMode {
  EXCLUSIVE
  INCLUSIVE
}

enum InventoryCategoryStatus {
  ACTIVE
  INACTIVE
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
}

enum TaxRegistrationType {
  VAT
  GST
  SALES_TAX_ID
  EIN
  OTHER
}

enum InventoryProductStatus {
  ACTIVE
  INACTIVE
}

enum PurchaseOrderStatus {
  DRAFT
  ORDERED
  RECEIVED
  CANCELED
}

enum LeaveDefinitionType {
  PAID
  LAY_OFF
  UNPAID
  RESTRICTED
  COMPENSATORY
  TOUR_ON_DUTY
}

enum LeaveDefinitionAllowedUsers {
  MALE
  FEMALE
  ALL
}

enum LeaveDefinitionStatus {
  ACTIVE
  INACTIVE
}

enum LeaveGroupAssignmentMode {
  ALL_STAFF
  SELECTED_STAFF
}

enum LeaveGroupStatus {
  ACTIVE
  INACTIVE
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
  REVOKED
}

enum StaffRosterDaySource {
  SCHEDULE
  OVERRIDE
  LEAVE
  UNAVAILABLE
  OFF
}

enum StaffSchedulingMode {
  STANDARD
  FLEXIBLE
}

enum StockMovementType {
  PURCHASE_RECEIPT
  ADJUSTMENT_ADD
  ADJUSTMENT_SUB
  BOOKING_PRODUCT_SALE
  BOOKING_PRODUCT_RESTOCK
}

model User {
  id                    String                    @id @default(cuid())
  tenantId              String?
  name                  String?
  email                 String                    @unique
  emailVerified         DateTime?
  image                 String?
  phone                 String?
  passwordHash          String?
  role                  Role                      @default(CUSTOMER)
  dateOfBirth           DateTime?
  gender                Gender?
  status                UserStatus                @default(ACTIVE)
  lastLoginAt           DateTime?
  marketingOptIn        Boolean                   @default(false)
  addressLine1          String?
  addressLine2          String?
  city                  String?
  state                 String?
  postalCode            String?
  country               String?
  accounts              Account[]
  sessions              Session[]
  invitations           Invitation[]              @relation("UserInvitations")
  passwordResetTokens   PasswordResetToken[]
  eligibleServices      StaffServiceEligibility[]
  staffProfile          StaffProfile?
  appointments          Appointment[]             @relation("CustomerAppointments")
  appointmentOrders     AppointmentOrder[]
  reviewedLeaveRequests LeaveRequest[]            @relation("LeaveRequestReviewedBy")
  revokedLeaveRequests  LeaveRequest[]            @relation("LeaveRequestRevokedBy")
  managedStaffProfiles  StaffProfile[]            @relation("StaffProfileManager")
  auditLogs             AuditLog[]                @relation("AuditLogActor")
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  tenant                Tenant?                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([tenantId])
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String?
  event       String
  entityType  String
  entityId    String?
  actorUserId String?
  actorRole   Role?
  requestId   String?
  metadata    Json?
  before      Json?
  after       Json?
  createdAt   DateTime @default(now())
  actorUser   User?    @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([event])
  @@index([entityType, entityId])
  @@index([actorUserId])
  @@index([requestId])
  @@index([createdAt])
  @@index([tenantId])
}

model Tenant {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  status      TenantStatus @default(ACTIVE)
  users       User[]
  invitations Invitation[]
  settings    AppSetting[]
  auditLogs   AuditLog[]
  serviceCategories ServiceCategory[]
  services    Service[]
  appointments Appointment[]
  appointmentOrders AppointmentOrder[]
  coupons     Coupon[]
  taxes       Tax[]
  inventoryCategories InventoryCategory[]
  suppliers   Supplier[]
  inventoryProducts InventoryProduct[]
  purchaseOrders PurchaseOrder[]
  stockMovements InventoryStockMovement[]
  shiftTemplates ShiftTemplate[]
  shiftSchedules ShiftSchedule[]
  leaveDefinitions LeaveDefinition[]
  leaveGroups LeaveGroup[]
  leaveRequests LeaveRequest[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status])
}

model ServiceCategory {
  id          String                @id @default(cuid())
  tenantId    String?
  name        String
  description String?
  status      ServiceCategoryStatus @default(ACTIVE)
  sortOrder   Int                   @default(0)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  services    Service[]
  tenant      Tenant?               @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([status])
  @@index([sortOrder])
}

model LeaveDefinition {
  id                       String                        @id @default(cuid())
  tenantId                 String?
  code                     String
  name                     String
  leaveType                LeaveDefinitionType
  allowedUsers             LeaveDefinitionAllowedUsers   @default(ALL)
  minDaysPerRequest        Int                           @default(1)
  maxDaysPerRequest        Int                           @default(30)
  allowWithOtherLeaves     Boolean                       @default(true)
  priorEntryAllowed        Boolean                       @default(false)
  noticeDays               Int                           @default(0)
  allowCarryForward        Boolean                       @default(false)
  weekOffSingleSideAllowed Boolean                       @default(true)
  weekOffBothSideAllowed   Boolean                       @default(true)
  holidaySingleSideAllowed Boolean                       @default(true)
  holidayBothSideAllowed   Boolean                       @default(true)
  maxConsecutiveDays       Int                           @default(30)
  maxPendingRequests       Int                           @default(3)
  status                   LeaveDefinitionStatus         @default(ACTIVE)
  sortOrder                Int                           @default(0)
  createdAt                DateTime                      @default(now())
  updatedAt                DateTime                      @updatedAt
  nonClubbableWithFrom     LeaveDefinitionNonClubbable[] @relation("LeaveDefinitionNonClubbableFrom")
  nonClubbableWithTo       LeaveDefinitionNonClubbable[] @relation("LeaveDefinitionNonClubbableTo")
  leaveGroups              LeaveGroupLeave[]
  leaveRequests            LeaveRequest[]
  tenant                   Tenant?                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([status])
  @@index([leaveType])
  @@index([sortOrder])
}

model LeaveGroup {
  id               String                      @id @default(cuid())
  tenantId         String?
  code             String
  name             String
  description      String?
  assignmentMode   LeaveGroupAssignmentMode    @default(ALL_STAFF)
  status           LeaveGroupStatus            @default(ACTIVE)
  sortOrder        Int                         @default(0)
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
  leaves           LeaveGroupLeave[]
  staffAssignments LeaveGroupStaffAssignment[]
  tenant           Tenant?                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([status])
  @@index([assignmentMode])
  @@index([sortOrder])
}

model LeaveGroupLeave {
  id                String          @id @default(cuid())
  leaveGroupId      String
  leaveDefinitionId String
  createdAt         DateTime        @default(now())
  leaveGroup        LeaveGroup      @relation(fields: [leaveGroupId], references: [id], onDelete: Cascade)
  leaveDefinition   LeaveDefinition @relation(fields: [leaveDefinitionId], references: [id], onDelete: Restrict)

  @@unique([leaveGroupId, leaveDefinitionId])
  @@index([leaveGroupId])
  @@index([leaveDefinitionId])
}

model LeaveGroupStaffAssignment {
  id             String       @id @default(cuid())
  leaveGroupId   String
  staffProfileId String
  createdAt      DateTime     @default(now())
  leaveGroup     LeaveGroup   @relation(fields: [leaveGroupId], references: [id], onDelete: Cascade)
  staffProfile   StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)

  @@unique([leaveGroupId, staffProfileId])
  @@index([leaveGroupId])
  @@index([staffProfileId])
}

model LeaveDefinitionNonClubbable {
  id                String          @id @default(cuid())
  leaveDefinitionId String
  blockedLeaveId    String
  leaveDefinition   LeaveDefinition @relation("LeaveDefinitionNonClubbableFrom", fields: [leaveDefinitionId], references: [id], onDelete: Cascade)
  blockedLeave      LeaveDefinition @relation("LeaveDefinitionNonClubbableTo", fields: [blockedLeaveId], references: [id], onDelete: Cascade)
  createdAt         DateTime        @default(now())

  @@unique([leaveDefinitionId, blockedLeaveId], map: "leave_def_nonclubbable_pair_key")
  @@index([leaveDefinitionId])
  @@index([blockedLeaveId])
}

model LeaveRequest {
  id                String                  @id @default(cuid())
  tenantId          String?
  staffProfileId    String
  leaveDefinitionId String
  startDate         DateTime                @db.Date
  endDate           DateTime                @db.Date
  daysCount         Float
  reason            String?
  status            LeaveRequestStatus      @default(PENDING)
  reviewedByUserId  String?
  reviewedAt        DateTime?
  reviewerComment   String?
  canceledAt        DateTime?
  cancelReason      String?
  revokedAt         DateTime?
  revokedByUserId   String?
  revokeReason      String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  staffProfile      StaffProfile            @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
  leaveDefinition   LeaveDefinition         @relation(fields: [leaveDefinitionId], references: [id], onDelete: Restrict)
  reviewedByUser    User?                   @relation("LeaveRequestReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  revokedByUser     User?                   @relation("LeaveRequestRevokedBy", fields: [revokedByUserId], references: [id], onDelete: SetNull)
  rosterHistoryDays StaffRosterHistoryDay[]
  tenant            Tenant?                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([staffProfileId])
  @@index([leaveDefinitionId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
  @@index([reviewedByUserId])
  @@index([revokedByUserId])
  @@index([createdAt])
}

model Service {
  id                    String                    @id @default(cuid())
  tenantId              String?
  name                  String
  description           String?
  durationMinutes       Int
  priceCents            Int
  status                ServiceStatus             @default(ACTIVE)
  type                  ServiceType               @default(STANDARD)
  taxMode               TaxMode                   @default(EXCLUSIVE)
  categoryId            String
  category              ServiceCategory           @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  packageItems          ServicePackageItem[]      @relation("PackageItems")
  includedIn            ServicePackageItem[]      @relation("PackageItemService")
  defaultTaxes          ServiceTax[]
  eligibleStaff         StaffServiceEligibility[]
  appointments          Appointment[]
  appointmentOrderLines AppointmentOrderLine[]
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  tenant                Tenant?                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
  @@index([categoryId])
  @@index([createdAt])
}

model Appointment {
  id             String                @id @default(cuid())
  tenantId       String?
  staffProfileId String
  customerId     String
  serviceId      String
  orderLineId    String?
  startAt        DateTime
  endAt          DateTime
  status         AppointmentStatus     @default(SCHEDULED)
  orderLine      AppointmentOrderLine? @relation(fields: [orderLineId], references: [id], onDelete: SetNull)
  staffProfile   StaffProfile          @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
  customer       User                  @relation("CustomerAppointments", fields: [customerId], references: [id], onDelete: Restrict)
  service        Service               @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  tenant         Tenant?               @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([staffProfileId])
  @@index([customerId])
  @@index([serviceId])
  @@index([orderLineId])
  @@index([startAt])
  @@index([endAt])
  @@index([status])
}

model AppointmentOrder {
  id                  String                        @id @default(cuid())
  tenantId            String?
  customerId          String
  appointmentDate     DateTime                      @db.Date
  appointmentStartAt  DateTime
  status              AppointmentOrderStatus        @default(DRAFT)
  customerNote        String?
  internalNote        String?
  subtotalCents       Int                           @default(0)
  lineDiscountCents   Int                           @default(0)
  couponDiscountCents Int                           @default(0)
  taxCents            Int                           @default(0)
  totalCents          Int                           @default(0)
  customer            User                          @relation(fields: [customerId], references: [id], onDelete: Restrict)
  lines               AppointmentOrderLine[]
  productLines        AppointmentOrderProductLine[]
  coupons             AppointmentOrderCoupon[]
  taxes               AppointmentOrderTax[]
  createdAt           DateTime                      @default(now())
  updatedAt           DateTime                      @updatedAt
  tenant              Tenant?                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([customerId])
  @@index([appointmentDate])
  @@index([appointmentStartAt])
  @@index([status])
}

model AppointmentOrderLine {
  id                String           @id @default(cuid())
  orderId           String
  sortOrder         Int              @default(0)
  serviceId         String
  staffProfileId    String
  quantity          Int              @default(1)
  durationMinutes   Int
  unitPriceCents    Int
  discountType      DiscountType     @default(NONE)
  discountValue     Float            @default(0)
  taxMode           TaxMode          @default(EXCLUSIVE)
  taxIds            String[]         @default([])
  lineSubtotalCents Int              @default(0)
  lineDiscountCents Int              @default(0)
  lineTaxCents      Int              @default(0)
  lineTotalCents    Int              @default(0)
  startAt           DateTime
  endAt             DateTime
  note              String?
  order             AppointmentOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  service           Service          @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  staffProfile      StaffProfile     @relation(fields: [staffProfileId], references: [id], onDelete: Restrict)
  appointments      Appointment[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([orderId])
  @@index([serviceId])
  @@index([staffProfileId])
  @@index([startAt])
  @@index([endAt])
}

model AppointmentOrderProductLine {
  id                String           @id @default(cuid())
  orderId           String
  sortOrder         Int              @default(0)
  productId         String
  quantity          Int              @default(1)
  unitPriceCents    Int
  discountType      DiscountType     @default(NONE)
  discountValue     Float            @default(0)
  taxMode           TaxMode          @default(EXCLUSIVE)
  taxIds            String[]         @default([])
  lineSubtotalCents Int              @default(0)
  lineDiscountCents Int              @default(0)
  lineTaxCents      Int              @default(0)
  lineTotalCents    Int              @default(0)
  note              String?
  order             AppointmentOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product           InventoryProduct @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([orderId])
  @@index([productId])
}

model AppointmentOrderCoupon {
  id            String           @id @default(cuid())
  orderId       String
  code          String
  discountType  DiscountType     @default(NONE)
  discountValue Float            @default(0)
  discountCents Int              @default(0)
  order         AppointmentOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt     DateTime         @default(now())

  @@index([orderId])
  @@index([code])
}

model ServicePackageItem {
  id            String   @id @default(cuid())
  packageId     String
  itemServiceId String
  sortOrder     Int      @default(0)
  package       Service  @relation("PackageItems", fields: [packageId], references: [id], onDelete: Cascade)
  itemService   Service  @relation("PackageItemService", fields: [itemServiceId], references: [id], onDelete: Restrict)
  createdAt     DateTime @default(now())

  @@unique([packageId, itemServiceId])
  @@index([packageId])
  @@index([itemServiceId])
}

model AppSetting {
  id                        String                  @id @default(cuid())
  tenantId                  String
  locale                    String                  @default("en-US")
  currency                  String                  @default("USD")
  timeZone                  String                  @default("America/New_York")
  dateFormat                String                  @default("MM/dd/yyyy")
  timeFormat                TimeFormat              @default(H24)
  firstDayOfWeek            Weekday                 @default(SUNDAY)
  emailNotificationsEnabled Boolean                 @default(false)
  currencySymbolPlacement   CurrencySymbolPlacement @default(BEFORE)
  numberFormat              NumberFormatStyle       @default(US_UK)
  updatedAt                 DateTime                @updatedAt
  workingDays               AppSettingDay[]
  overrides                 AppSettingOverride[]
  tenant                    Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId])
}

model Coupon {
  id                 String             @id @default(cuid())
  tenantId           String?
  code               String
  name               String?
  discountType       DiscountType       @default(NONE)
  discountValue      Float              @default(0)
  appliesTo          CouponAppliesTo    @default(ORDER)
  allowedServiceIds  String[]           @default([])
  allowedCategoryIds String[]           @default([])
  allowedProductIds  String[]           @default([])
  minSubtotalCents   Int                @default(0)
  stackingMode       CouponStackingMode @default(STACKABLE)
  isActive           Boolean            @default(true)
  validFrom          DateTime?          @db.Date
  validTo            DateTime?          @db.Date
  maxUses            Int?
  maxUsesPerCustomer Int?
  usedCount          Int                @default(0)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  tenant             Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([isActive])
  @@index([code])
}

model Tax {
  id                String                @id @default(cuid())
  tenantId          String?
  name              String
  percent           Float
  isActive          Boolean               @default(true)
  sortOrder         Int                   @default(0)
  services          ServiceTax[]
  inventoryProducts InventoryProductTax[]
  orders            AppointmentOrderTax[]
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  tenant            Tenant?               @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([isActive])
  @@index([sortOrder])
}

model ServiceTax {
  serviceId String
  taxId     String
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  tax       Tax      @relation(fields: [taxId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())

  @@id([serviceId, taxId])
  @@index([taxId])
}

model AppointmentOrderTax {
  id        String           @id @default(cuid())
  orderId   String
  taxId     String?
  name      String
  percent   Float
  taxCents  Int              @default(0)
  order     AppointmentOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  tax       Tax?             @relation(fields: [taxId], references: [id], onDelete: SetNull)
  createdAt DateTime         @default(now())

  @@index([orderId])
  @@index([taxId])
}

model AppSettingDay {
  id        String             @id @default(cuid())
  settingId String
  day       Weekday
  isOpen    Boolean            @default(true)
  setting   AppSetting         @relation(fields: [settingId], references: [id], onDelete: Cascade)
  periods   AppSettingPeriod[]

  @@unique([settingId, day])
}

model AppSettingPeriod {
  id        String               @id @default(cuid())
  dayId     String
  kind      AppSettingPeriodType
  startTime String
  endTime   String
  sortOrder Int                  @default(0)
  day       AppSettingDay        @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@index([dayId])
}

model AppSettingOverride {
  id        String                     @id @default(cuid())
  settingId String
  date      DateTime                   @db.Date
  isOpen    Boolean                    @default(true)
  setting   AppSetting                 @relation(fields: [settingId], references: [id], onDelete: Cascade)
  periods   AppSettingOverridePeriod[]

  @@unique([settingId, date])
  @@index([settingId])
  @@index([date])
}

model AppSettingOverridePeriod {
  id         String               @id @default(cuid())
  overrideId String
  kind       AppSettingPeriodType
  startTime  String
  endTime    String
  sortOrder  Int                  @default(0)
  override   AppSettingOverride   @relation(fields: [overrideId], references: [id], onDelete: Cascade)

  @@index([overrideId])
}

model StaffServiceEligibility {
  id        String   @id @default(cuid())
  userId    String
  serviceId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())

  @@unique([userId, serviceId])
  @@index([userId])
  @@index([serviceId])
}

model StaffProfile {
  id                    String                      @id @default(cuid())
  userId                String                      @unique
  managerUserId         String?
  schedulingMode        StaffSchedulingMode         @default(STANDARD)
  user                  User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  manager               User?                       @relation("StaffProfileManager", fields: [managerUserId], references: [id], onDelete: SetNull)
  appointments          Appointment[]
  appointmentOrderLines AppointmentOrderLine[]
  certifications        StaffCertification[]
  documents             StaffDocument[]
  flexibleSlots         StaffFlexibleAvailability[]
  flexibleWeekPlans     StaffFlexibleWeekPlan[]
  flexiblePatterns      StaffFlexiblePattern[]
  scheduleAssignments   StaffScheduleAssignment[]
  shiftOverrides        StaffShiftOverride[]
  leaveGroupAssignments LeaveGroupStaffAssignment[]
  leaveRequests         LeaveRequest[]
  rosterHistoryDays     StaffRosterHistoryDay[]
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt

  @@index([managerUserId])
}

model StaffRosterHistoryDay {
  id                  String               @id @default(cuid())
  staffProfileId      String
  date                DateTime             @db.Date
  source              StaffRosterDaySource
  templateId          String?
  templateName        String?
  startTime           String?
  endTime             String?
  paidMinutes         Int                  @default(0)
  leaveRequestId      String?
  leaveDefinitionCode String?
  leaveDefinitionName String?
  leaveReason         String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  staffProfile        StaffProfile         @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
  template            ShiftTemplate?       @relation(fields: [templateId], references: [id], onDelete: SetNull)
  leaveRequest        LeaveRequest?        @relation(fields: [leaveRequestId], references: [id], onDelete: SetNull)

  @@unique([staffProfileId, date])
  @@index([date])
  @@index([staffProfileId])
  @@index([source])
}

model StaffCertification {
  id             String       @id @default(cuid())
  staffProfileId String
  title          String
  issuer         String?
  issuedAt       DateTime?    @db.Date
  expiresAt      DateTime?    @db.Date
  staffProfile   StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([staffProfileId])
}

model StaffDocument {
  id             String            @id @default(cuid())
  staffProfileId String
  type           StaffDocumentType
  number         String?
  imageUrl       String
  validFrom      DateTime?         @db.Date
  validTo        DateTime?         @db.Date
  staffProfile   StaffProfile      @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
  createdAt      DateTime          @default(now())

  @@index([staffProfileId])
}

model ShiftTemplate {
  id                String                  @id @default(cuid())
  tenantId          String?
  name              String
  description       String?
  color             String?
  isActive          Boolean                 @default(true)
  startTime         String
  endTime           String
  breaks            ShiftTemplateBreak[]
  schedules         ShiftScheduleBlock[]
  overrides         StaffShiftOverride[]
  rosterHistoryDays StaffRosterHistoryDay[]
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  tenant            Tenant?                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([isActive])
  @@index([createdAt])
}

model ShiftTemplateBreak {
  id         String        @id @default(cuid())
  templateId String
  startTime  String
  endTime    String
  sortOrder  Int           @default(0)
  template   ShiftTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

model ShiftSchedule {
  id            String                    @id @default(cuid())
  tenantId      String?
  name          String?
  isDefault     Boolean                   @default(false)
  startDate     DateTime                  @db.Date
  weekOffDay1   Weekday
  weekOffDay2   Weekday?
  weekOff2Weeks Int[]
  blocks        ShiftScheduleBlock[]
  assignments   StaffScheduleAssignment[]
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  tenant        Tenant?                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([startDate])
}

model ShiftScheduleBlock {
  id         String        @id @default(cuid())
  scheduleId String
  templateId String
  repeatDays Int
  sortOrder  Int           @default(0)
  schedule   ShiftSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  template   ShiftTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)

  @@index([scheduleId])
  @@index([templateId])
}

model StaffScheduleAssignment {
  id             String        @id @default(cuid())
  staffProfileId String
  scheduleId     String
  startDate      DateTime      @db.Date
  endDate        DateTime?     @db.Date
  staffProfile   StaffProfile  @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
  schedule       ShiftSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([staffProfileId])
  @@index([scheduleId])
  @@index([startDate])
  @@index([endDate])
}

model StaffShiftOverride {
  id             String         @id @default(cuid())
  staffProfileId String
  date           DateTime       @db.Date
  templateId     String?
  staffProfile   StaffProfile   @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
  template       ShiftTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([staffProfileId, date])
  @@index([staffProfileId])
  @@index([date])
  @@index([templateId])
}

model StaffFlexibleAvailability {
  id             String       @id @default(cuid())
  staffProfileId String
  date           DateTime     @db.Date
  startTime      String
  endTime        String
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  staffProfile   StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)

  @@unique([staffProfileId, date, sortOrder])
  @@index([staffProfileId])
  @@index([date])
}

model StaffFlexibleWeekPlan {
  id             String                 @id @default(cuid())
  staffProfileId String
  weekStartDate  DateTime               @db.Date
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  staffProfile   StaffProfile           @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
  days           StaffFlexibleWeekDay[]

  @@unique([staffProfileId, weekStartDate])
  @@index([staffProfileId])
  @@index([weekStartDate])
}

model StaffFlexibleWeekDay {
  id         String                  @id @default(cuid())
  planId     String
  day        Weekday
  isOff      Boolean                 @default(false)
  sortOrder  Int                     @default(0)
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt
  plan       StaffFlexibleWeekPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  slots      StaffFlexibleWeekSlot[]

  @@unique([planId, day])
  @@index([planId])
  @@index([day])
}

model StaffFlexibleWeekSlot {
  id         String                    @id @default(cuid())
  dayId      String
  startTime  String
  endTime    String
  sortOrder  Int                       @default(0)
  createdAt  DateTime                  @default(now())
  updatedAt  DateTime                  @updatedAt
  day        StaffFlexibleWeekDay      @relation(fields: [dayId], references: [id], onDelete: Cascade)
  breaks     StaffFlexibleWeekBreak[]

  @@unique([dayId, sortOrder])
  @@index([dayId])
}

model StaffFlexibleWeekBreak {
  id         String                @id @default(cuid())
  slotId     String
  startTime  String
  endTime    String
  sortOrder  Int                   @default(0)
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  slot       StaffFlexibleWeekSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)

  @@unique([slotId, sortOrder])
  @@index([slotId])
}

model StaffFlexiblePattern {
  id               String                    @id @default(cuid())
  staffProfileId   String
  name             String?
  cycleLengthWeeks Int                       @default(1)
  validFrom        DateTime                  @db.Date
  validTo          DateTime?                 @db.Date
  isActive         Boolean                   @default(true)
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  staffProfile     StaffProfile              @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
  weeks            StaffFlexiblePatternWeek[]

  @@index([staffProfileId])
  @@index([validFrom])
  @@index([validTo])
  @@index([isActive])
}

model StaffFlexiblePatternWeek {
  id        String                    @id @default(cuid())
  patternId String
  weekIndex Int
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt
  pattern   StaffFlexiblePattern      @relation(fields: [patternId], references: [id], onDelete: Cascade)
  days      StaffFlexiblePatternDay[]

  @@unique([patternId, weekIndex])
  @@index([patternId])
}

model StaffFlexiblePatternDay {
  id        String                     @id @default(cuid())
  weekId    String
  day       Weekday
  isOff     Boolean                    @default(false)
  sortOrder Int                        @default(0)
  createdAt DateTime                   @default(now())
  updatedAt DateTime                   @updatedAt
  week      StaffFlexiblePatternWeek   @relation(fields: [weekId], references: [id], onDelete: Cascade)
  slots     StaffFlexiblePatternSlot[]

  @@unique([weekId, day])
  @@index([weekId])
  @@index([day])
}

model StaffFlexiblePatternSlot {
  id        String                       @id @default(cuid())
  dayId     String
  startTime String
  endTime   String
  sortOrder Int                          @default(0)
  createdAt DateTime                     @default(now())
  updatedAt DateTime                     @updatedAt
  day       StaffFlexiblePatternDay      @relation(fields: [dayId], references: [id], onDelete: Cascade)
  breaks    StaffFlexiblePatternBreak[]

  @@unique([dayId, sortOrder])
  @@index([dayId])
}

model StaffFlexiblePatternBreak {
  id        String                    @id @default(cuid())
  slotId    String
  startTime String
  endTime   String
  sortOrder Int                       @default(0)
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt
  slot      StaffFlexiblePatternSlot  @relation(fields: [slotId], references: [id], onDelete: Cascade)

  @@unique([slotId, sortOrder])
  @@index([slotId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Invitation {
  id          String    @id @default(cuid())
  tenantId    String?
  email       String
  token       String    @unique
  role        Role      @default(CUSTOMER)
  expiresAt   DateTime
  acceptedAt  DateTime?
  invitedById String?
  invitedBy   User?     @relation("UserInvitations", fields: [invitedById], references: [id], onDelete: SetNull)
  tenant      Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@index([email])
  @@index([tenantId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model InventoryCategory {
  id          String                  @id @default(cuid())
  tenantId    String?
  name        String
  description String?
  status      InventoryCategoryStatus @default(ACTIVE)
  sortOrder   Int                     @default(0)
  products    InventoryProduct[]
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  tenant      Tenant?                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([status])
  @@index([sortOrder])
}

model Supplier {
  id                    String                     @id @default(cuid())
  tenantId              String?
  name                  String
  contactPerson         String?
  email                 String?
  phone                 String?
  isTaxRegistered       Boolean                    @default(false)
  taxRegistrationType   TaxRegistrationType?
  taxRegistrationNumber String?
  leadTimeDays          Int                        @default(0)
  addressLine1          String?
  addressLine2          String?
  city                  String?
  state                 String?
  postalCode            String?
  country               String?
  notes                 String?
  status                SupplierStatus             @default(ACTIVE)
  products              InventoryProductSupplier[]
  purchaseOrders        PurchaseOrder[]
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  tenant                Tenant?                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([name])
  @@index([status])
}

model InventoryProduct {
  id                           String                        @id @default(cuid())
  tenantId                     String?
  sku                          String
  name                         String
  description                  String?
  unit                         String                        @default("unit")
  categoryId                   String
  status                       InventoryProductStatus        @default(ACTIVE)
  costPriceCents               Int                           @default(0)
  mrpCents                     Int                           @default(0)
  reorderPoint                 Int                           @default(0)
  reorderQty                   Int                           @default(0)
  onHandQty                    Int                           @default(0)
  isPhysical                   Boolean                       @default(true)
  category                     InventoryCategory             @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  suppliers                    InventoryProductSupplier[]
  taxes                        InventoryProductTax[]
  purchaseItems                PurchaseOrderItem[]
  appointmentOrderProductLines AppointmentOrderProductLine[]
  stockMovements               InventoryStockMovement[]
  createdAt                    DateTime                      @default(now())
  updatedAt                    DateTime                      @updatedAt
  tenant                       Tenant?                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([name])
  @@index([status])
  @@index([categoryId])
  @@index([onHandQty])
}

model InventoryProductSupplier {
  productId         String
  supplierId        String
  supplierSku       String?
  supplierCostCents Int?
  minOrderQty       Int              @default(1)
  leadTimeDays      Int?
  isPreferred       Boolean          @default(false)
  lastPurchasedAt   DateTime?
  product           InventoryProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier          Supplier         @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@id([productId, supplierId])
  @@index([supplierId])
  @@index([isPreferred])
}

model InventoryProductTax {
  productId String
  taxId     String
  product   InventoryProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  tax       Tax              @relation(fields: [taxId], references: [id], onDelete: Restrict)
  createdAt DateTime         @default(now())

  @@id([productId, taxId])
  @@index([taxId])
}

model PurchaseOrder {
  id            String              @id @default(cuid())
  tenantId      String?
  orderNumber   String
  supplierId    String
  status        PurchaseOrderStatus @default(DRAFT)
  orderDate     DateTime            @db.Date
  expectedDate  DateTime?           @db.Date
  notes         String?
  subtotalCents Int                 @default(0)
  taxCents      Int                 @default(0)
  totalCents    Int                 @default(0)
  receivedAt    DateTime?
  supplier      Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  items         PurchaseOrderItem[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  tenant        Tenant?             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@index([supplierId])
  @@index([status])
  @@index([orderDate])
}

model PurchaseOrderItem {
  id                String                   @id @default(cuid())
  orderId           String
  productId         String
  quantity          Int
  receivedQty       Int                      @default(0)
  unitCostCents     Int
  taxPercent        Float                    @default(0)
  lineSubtotalCents Int                      @default(0)
  lineTaxCents      Int                      @default(0)
  lineTotalCents    Int                      @default(0)
  order             PurchaseOrder            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product           InventoryProduct         @relation(fields: [productId], references: [id], onDelete: Restrict)
  stockMovements    InventoryStockMovement[]
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  @@index([orderId])
  @@index([productId])
}

model InventoryStockMovement {
  id            String             @id @default(cuid())
  tenantId      String?
  productId     String
  orderItemId   String?
  type          StockMovementType
  quantityDelta Int
  unitCostCents Int?
  note          String?
  occurredAt    DateTime           @default(now())
  product       InventoryProduct   @relation(fields: [productId], references: [id], onDelete: Restrict)
  orderItem     PurchaseOrderItem? @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  createdAt     DateTime           @default(now())
  tenant        Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([productId])
  @@index([orderItemId])
  @@index([type])
  @@index([occurredAt])
}
